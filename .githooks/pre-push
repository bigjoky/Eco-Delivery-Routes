#!/usr/bin/env bash
set -euo pipefail

branch="$(git rev-parse --abbrev-ref HEAD)"

if [[ "$branch" == "main" ]]; then
  echo "Direct push to main is blocked by local hook. Use a PR branch."
  echo "Override: export ALLOW_PUSH_MAIN=1"
  if [[ "${ALLOW_PUSH_MAIN:-}" != "1" ]]; then
    exit 1
  fi
fi
