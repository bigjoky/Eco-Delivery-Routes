{
  "name": "eco-delivery-routes/backend",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0",
    "inertiajs/inertia-laravel": "^2.0",
    "barryvdh/laravel-dompdf": "^3.1",
    "laravel/breeze": "^2.3",
    "tightenco/ziggy": "^2.0",
    "symfony/yaml": "^7.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "fakerphp/faker": "^1.24",
    "laravel/pail": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fca5a5,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\""
    ],
    "dev:lan": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fca5a5,#fdba74\" \"php artisan serve --host=0.0.0.0 --port=8001\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev:host\""
    ]
  }
}
